<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Queue</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div>
                <div class="brand">
                    <div class="brand-badge">SQ</div>
                    <div>
                        <div class="brand-title">Smart Queue</div>
                        <div class="brand-subtitle">Admin Dashboard</div>
                    </div>
                </div>

                <nav class="sidebar-nav mt-4">
                    <a class="nav-item-custom active" asp-controller="Dashboard" asp-action="Index">
                        Dashboard
                    </a>
                    <a class="nav-item-custom" href="/swagger">
                        Swagger API
                    </a>
                </nav>
            </div>

            <div class="sidebar-footer">
                Queue monitoring system
            </div>
        </aside>

        <div class="main-content">
            <header class="topbar">
                <div>
                    <h2 class="page-title mb-1">@ViewData["Title"]</h2>
                    <div class="page-subtitle">Operational overview and ticket monitoring</div>
                </div>
                <a href="/swagger" class="btn btn-dark rounded-pill px-4">Open Swagger</a>
            </header>

            <main class="content-area">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>