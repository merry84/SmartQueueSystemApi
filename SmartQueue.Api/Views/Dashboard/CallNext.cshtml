@model SmartQueue.Api.ViewModels.Dashboard.Forms.CallNextFormViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Call Next Ticket";
}

<div class="panel-card">
    <div class="panel-header">
        <div>
            <h4 class="panel-title">Call Next Ticket</h4>
            <p class="panel-subtitle">Select queue and call the next waiting ticket</p>
        </div>
    </div>
    <div class="panel-body">
        <form asp-action="CallNext" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="QueueId" class="form-label"></label>
                <select asp-for="QueueId" asp-items="Model.Queues" class="form-select">
                    <option value="">Select queue</option>
                </select>
                <span asp-validation-for="QueueId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark rounded-pill px-4">Call Next</button>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Back</a>
            </div>
        </form>
    </div>
</div>