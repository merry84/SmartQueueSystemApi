@model SmartQueue.Api.ViewModels.Dashboard.Forms.CallNextFormViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Call Next Ticket";
}

<div class="panel-card">
    <div class="panel-header">
        <div>
            <h4 class="panel-title">Call Next Ticket</h4>
            <p class="panel-subtitle">Select queue and call the next waiting ticket</p>
        </div>
    </div>
    <div class="panel-body">
        <form action="/Dashboard/CallNext" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label" for="QueueId">Queue</label>
                <select id="QueueId" name="QueueId" class="form-select">
                    <option value="">Select queue</option>

                    @foreach (var q in Model.Queues)
                    {
                        if (q.Value == Model.QueueId.ToString())
                        {
                            <option value="@q.Value" selected>@q.Text</option>
                        }
                        else
                        {
                            <option value="@q.Value">@q.Text</option>
                        }
                    }
                </select>
                <span asp-validation-for="QueueId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark rounded-pill px-4">Call Next</button>
                <a href="/Dashboard" class="btn btn-outline-secondary rounded-pill px-4">Back</a>
            </div>
        </form>
    </div>
</div>