@model SmartQueue.Api.ViewModels.Dashboard.DashboardIndexViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="hero-card mb-4">
    <div>
        <div class="hero-label">SMART QUEUE MONITORING</div>
        <h1 class="hero-title">Real-time queue control panel</h1>
        <p class="hero-text mb-0">
            Track queue load, recent tickets and service performance from one place.
        </p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="panel-card mb-4">
    <div class="panel-header">
        <div>
            <h4 class="panel-title">Quick Actions</h4>
            <p class="panel-subtitle">Manage queues and tickets directly from the dashboard</p>
        </div>
    </div>
    <div class="panel-body">
        <div class="row g-3 justify-content-center">
            <div class="col-md-6 col-xl-3">
                <a href="/Dashboard/CreateQueue" class="action-card action-blue">
                    <div class="action-title">Create Queue</div>
                    <div class="action-text">Add a new queue with service time.</div>
                </a>
            </div>
            <div class="col-md-6 col-xl-3">
                <a href="/Dashboard/JoinQueue" class="action-card action-green">
                    <div class="action-title">Join Queue</div>
                    <div class="action-text">Register a new customer ticket.</div>
                </a>
            </div>
            <div class="col-md-6 col-xl-3">
                <a href="/Dashboard/CallNext" class="action-card action-orange">
                    <div class="action-title">Call Next</div>
                    <div class="action-text">Move the next ticket to called state.</div>
                </a>
            </div>
            
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="trend-card trend-blue">
            <div class="trend-label">Tickets Today</div>
            <div class="trend-value">@Model.TicketsCreatedToday</div>
            <div class="trend-meta">New queue entries today</div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="trend-card trend-green">
            <div class="trend-label">Served Today</div>
            <div class="trend-value">@Model.TicketsServedToday</div>
            <div class="trend-meta">Completed successfully</div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="trend-card trend-orange">
            <div class="trend-label">Called Today</div>
            <div class="trend-value">@Model.TicketsCalledToday</div>
            <div class="trend-meta">Moved to called state</div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="trend-card trend-dark">
            <div class="trend-label">Service Rate</div>
            <div class="trend-value">@Model.ServiceRatePercent.ToString("0.0")%</div>
            <div class="trend-meta">Served vs created today</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xxl-3">
        <div class="stat-card">
            <div class="stat-label">Total Queues</div>
            <div class="stat-value">@Model.TotalQueues</div>
            <div class="stat-meta">Active: @Model.ActiveQueues</div>
        </div>
    </div>

    <div class="col-md-6 col-xxl-3">
        <div class="stat-card">
            <div class="stat-label">Total Tickets</div>
            <div class="stat-value">@Model.TotalTickets</div>
            <div class="stat-meta">All time activity</div>
        </div>
    </div>

    <div class="col-md-6 col-xxl-3">
        <div class="stat-card">
            <div class="stat-label">Waiting Tickets</div>
            <div class="stat-value">@Model.WaitingTickets</div>
            <div class="stat-meta">Called: @Model.CalledTickets</div>
        </div>
    </div>

    <div class="col-md-6 col-xxl-3">
        <div class="stat-card">
            <div class="stat-label">Average Wait Time</div>
            <div class="stat-value">@Model.AverageWaitTimeMinutes.ToString("0.0") min</div>
            <div class="stat-meta">Top queue: @Model.MostRequestedQueueName</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-8">
        <div class="panel-card">
            <div class="panel-header">
                <div>
                    <h4 class="panel-title">Operational Progress</h4>
                    <p class="panel-subtitle">Live snapshot of ticket distribution</p>
                </div>
            </div>
            <div class="panel-body">
                <div class="progress-group">
                    <div class="progress-row">
                        <div class="progress-title">Waiting Tickets</div>
                        <div class="progress-value">@Model.WaitingTickets</div>
                    </div>
                    <div class="progress modern-progress">
                        <div class="progress-bar bg-warning"
                             style="width:@(Model.TotalTickets > 0 ? (Model.WaitingTickets * 100.0 / Model.TotalTickets).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) : "0")%">
                        </div>
                    </div>
                </div>

                <div class="progress-group">
                    <div class="progress-row">
                        <div class="progress-title">Called Tickets</div>
                        <div class="progress-value">@Model.CalledTickets</div>
                    </div>
                    <div class="progress modern-progress">
                        <div class="progress-bar bg-info"
                             style="width:@(Model.TotalTickets > 0 ? (Model.CalledTickets * 100.0 / Model.TotalTickets).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) : "0")%">
                        </div>
                    </div>
                </div>

                <div class="progress-group">
                    <div class="progress-row">
                        <div class="progress-title">Served Tickets</div>
                        <div class="progress-value">@Model.ServedTickets</div>
                    </div>
                    <div class="progress modern-progress">
                        <div class="progress-bar bg-success"
                             style="width:@(Model.TotalTickets > 0 ? (Model.ServedTickets * 100.0 / Model.TotalTickets).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) : "0")%">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="panel-card h-100">
            <div class="panel-header">
                <div>
                    <h4 class="panel-title">Performance Insight</h4>
                    <p class="panel-subtitle">Quick interpretation</p>
                </div>
            </div>
            <div class="panel-body">
                <div class="insight-box mb-3">
                    <div class="insight-label">Most Requested Queue</div>
                    <div class="insight-value">@Model.MostRequestedQueueName</div>
                </div>

                <div class="insight-box mb-3">
                    <div class="insight-label">Average Wait Time</div>
                    <div class="insight-value">@Model.AverageWaitTimeMinutes.ToString("0.0") min</div>
                </div>

                <div class="insight-box">
                    <div class="insight-label">Today Service Rate</div>
                    <div class="insight-value">@Model.ServiceRatePercent.ToString("0.0")%</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-7">
        <div class="panel-card">
            <div class="panel-header">
                <div>
                    <h4 class="panel-title">Tickets (Last 7 Days)</h4>
                    <p class="panel-subtitle">Daily created tickets overview</p>
                </div>
            </div>
            <div class="panel-body">
                <canvas id="ticketsChart" height="120"></canvas>
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        <div class="panel-card">
            <div class="panel-header">
                <div>
                    <h4 class="panel-title">Top Queues</h4>
                    <p class="panel-subtitle">Most requested queues</p>
                </div>
            </div>
            <div class="panel-body">
                <canvas id="queueChart" height="120"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-5">
        <div class="panel-card h-100">
            <div class="panel-header">
                <div>
                    <h4 class="panel-title">Queue Load</h4>
                    <p class="panel-subtitle">Current load by queue</p>
                </div>
            </div>

            <div class="panel-body">
                @if (!Model.TopQueues.Any())
                {
                    <div class="empty-state">No queues available yet.</div>
                }
                else
                {
                    @foreach (var queue in Model.TopQueues)
                    {
                        <div class="queue-item">
                            <div class="queue-item-top">
                                <div>
                                    <h5 class="queue-name">@queue.QueueName</h5>
                                    <span class="status-pill @(queue.IsActive ? "status-active" : "status-inactive")">
                                        @(queue.IsActive ? "Active" : "Inactive")
                                    </span>
                                </div>
                                <div class="avg-pill">@queue.AverageServiceTimeMinutes min avg</div>
                            </div>

                            <div class="row g-2 mt-1">
                                <div class="col-4">
                                    <div class="mini-stat">
                                        <div class="mini-stat-value">@queue.WaitingTickets</div>
                                        <div class="mini-stat-label">Waiting</div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="mini-stat">
                                        <div class="mini-stat-value">@queue.CalledTickets</div>
                                        <div class="mini-stat-label">Called</div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="mini-stat">
                                        <div class="mini-stat-value">@queue.ServedTickets</div>
                                        <div class="mini-stat-label">Served</div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex gap-2 mt-3">
                                <a href="/Dashboard/JoinQueue?queueId=@queue.QueueId"
                                   class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    Join
                                </a>

                                <a href="/Dashboard/CallNext?queueId=@queue.QueueId"
                                   class="btn btn-sm btn-outline-dark rounded-pill px-3">
                                    Call Next
                                </a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="panel-card h-100">
            <div class="panel-header">
                <div>
                    <h4 class="panel-title">Recent Tickets</h4>
                    <p class="panel-subtitle">Latest customer activity</p>
                </div>
            </div>

            <div class="panel-body">
                @if (!Model.RecentTickets.Any())
                {
                    <div class="empty-state">No tickets available yet.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-modern align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Customer</th>
                                    <th>Queue</th>
                                    <th>Status</th>
                                    <th>Priority</th>
                                    <th>Est. Wait</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ticket in Model.RecentTickets)
                                {
                                    <tr>
                                        <td class="fw-semibold">@ticket.Number</td>
                                        <td>@ticket.CustomerName</td>
                                        <td>@ticket.QueueName</td>
                                        <td>
                                            <span class="status-pill @(ticket.Status == "Waiting" ? "pill-waiting" : ticket.Status == "Called" ? "pill-called" : "pill-served")">
                                                @ticket.Status
                                            </span>
                                        </td>
                                        <td>
                                            <span class="status-pill @(ticket.Priority == "VIP" ? "pill-vip" : "pill-normal")">
                                                @ticket.Priority
                                            </span>
                                        </td>
                                        <td>@ticket.EstimatedWaitTimeMinutes min</td>
                                        <td>
                                            @if (ticket.Status == "Called")
                                            {
                                                <form action="/Dashboard/ServeTicket" method="post" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="TicketId" value="@ticket.TicketId" />
                                                    <button type="submit" class="btn btn-sm btn-success rounded-pill px-3">
                                                        Serve
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const ticketsLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last7DaysLabels));
        const ticketsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TicketsLast7Days));
        const queueLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.QueueNames));
        const queueData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TicketsPerQueue));

        const ticketsChartCanvas = document.getElementById('ticketsChart');
        if (ticketsChartCanvas) {
            new Chart(ticketsChartCanvas, {
                type: 'line',
                data: {
                    labels: ticketsLabels,
                    datasets: [{
                        label: 'Tickets',
                        data: ticketsData,
                        borderColor: '#2563eb',
                        backgroundColor: 'rgba(37, 99, 235, 0.12)',
                        fill: true,
                        tension: 0.35,
                        borderWidth: 3,
                        pointBackgroundColor: '#2563eb',
                        pointBorderColor: '#2563eb',
                        pointRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            display: true
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0
                            }
                        }
                    }
                }
            });
        }

        const queueChartCanvas = document.getElementById('queueChart');
        if (queueChartCanvas) {
            new Chart(queueChartCanvas, {
                type: 'bar',
                data: {
                    labels: queueLabels,
                    datasets: [{
                        label: 'Tickets',
                        data: queueData,
                        backgroundColor: [
                            '#2563eb',
                            '#22c55e',
                            '#f97316',
                            '#7c3aed',
                            '#06b6d4'
                        ],
                        borderRadius: 10
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            display: true
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0
                            }
                        }
                    }
                }
            });
        }

        setTimeout(() => {
            window.location.reload();
        }, 15000);
    </script>
}