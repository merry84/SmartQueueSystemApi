@model SmartQueue.Api.ViewModels.Dashboard.Forms.CreateQueueFormViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Create Queue";
}

<div class="panel-card">
    <div class="panel-header">
        <div>
            <h4 class="panel-title">Create Queue</h4>
            <p class="panel-subtitle">Add a new queue to the system</p>
        </div>
    </div>

    <div class="panel-body">
        <form action="/Dashboard/CreateQueue" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label" for="Name">Queue Name</label>
                <input id="Name"
                       name="Name"
                       value="@Model.Name"
                       class="form-control"
                       placeholder="Enter queue name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" for="Description">Description</label>
                <textarea id="Description"
                          name="Description"
                          class="form-control"
                          rows="3"
                          placeholder="Enter short description">@Model.Description</textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" for="AverageServiceTimeMinutes">Average Service Time (minutes)</label>
                <input id="AverageServiceTimeMinutes"
                       name="AverageServiceTimeMinutes"
                       value="@Model.AverageServiceTimeMinutes"
                       class="form-control"
                       type="number"
                       min="1"
                       max="120" />
                <span asp-validation-for="AverageServiceTimeMinutes" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark rounded-pill px-4">Create</button>
                <a href="/Dashboard" class="btn btn-outline-secondary rounded-pill px-4">Back</a>
            </div>
        </form>
    </div>
</div>