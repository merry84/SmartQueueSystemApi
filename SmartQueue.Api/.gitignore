## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
bin/
obj/

# Visual Studio folder
.vs/

# Rider
.idea/

# Logs
*.log

# ASP.NET Core
appsettings.Development.json

# Entity Framework
Migrations/*Designer.cs

# NuGet
*.nupkg
packages/

# OS files
.DS_Store
Thumbs.db

# Publish output
publish/

# Node (ако някога добавиш frontend)
node_modules/

# Coverage
coverage/